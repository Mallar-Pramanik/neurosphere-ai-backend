# ===== API SETTINGS =====
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ===== DATABASE SETTINGS =====
# SQLite (default)
DATABASE_URL=sqlite:///./neurosphere_ai.db

# PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/neurosphere_ai

# MySQL
# DATABASE_URL=mysql://username:password@localhost:3306/neurosphere_ai

# ===== JWT SECURITY =====
SECRET_KEY=your-super-secret-key-change-this-in-production-with-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== ODYSSEUS AI SETTINGS =====
# Local model path
ODYSSEUS_MODEL_PATH=./models/odysseus_ai

# Model parameters
ODYSSEUS_MAX_TOKENS=2048
ODYSSEUS_TEMPERATURE=0.7
ODYSSEUS_TOP_P=0.9

# Enable/Disable features
ENABLE_ODYSSEUS_AI=True

# ===== GOOGLE API SETTINGS =====
GOOGLE_CREDENTIALS_PATH=./credentials/google-credentials.json
GOOGLE_PROJECT_ID=your-google-project-id

# Optional: If using service account
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-credentials.json

ENABLE_GOOGLE_APIS=True

# ===== LOGGING SETTINGS =====
LOG_LEVEL=INFO
LOG_FILE=./logs/neurosphere_ai.log

# ===== FEATURE FLAGS =====
ENABLE_FILE_PROCESSING=True
ENABLE_CACHE=True
CACHE_EXPIRATION=3600

# ===== RATE LIMITING =====
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ===== FILE UPLOAD SETTINGS =====
MAX_UPLOAD_SIZE=10485760

# ===== EMAIL SETTINGS (Optional for SMTP) =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ===== FRONTEND URL =====
FRONTEND_URL=http://localhost:3000

# ===== SECURITY HEADERS =====
# CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
